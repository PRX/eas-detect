  "author": "Andrew Kuklewicz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PRX/eas-detect.git"
  },
  "bugs": {
    "url": "https://github.com/PRX/eas-detect/issues"
  },
  "homepage": "https://github.com/PRX/eas-detect#readme",
  "devDependencies": {
    "jest": "^30.3.0"
  }
